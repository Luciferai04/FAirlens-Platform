# FairLens Environment Configuration
# Copy to .env and fill in values

GCP_PROJECT_ID=YOUR_PROJECT_ID
GCP_REGION=us-central1
BQ_DATASET=fairlens

# Pub/Sub
PUBSUB_TOPIC=fairlens-predictions
BIAS_INCIDENTS_TOPIC=fairlens-bias-incidents
SCAN_REQUESTS_TOPIC=fairlens-scan-requests

# Vertex AI
VERTEX_ENDPOINT_ID=

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# KMS
KMS_KEY_RING=fairlens-keys
KMS_KEY_ID=compliance-signer

# Spanner (for compliance report hashes)
SPANNER_INSTANCE=fairlens-audit
SPANNER_DATABASE=compliance

# Console
CONSOLE_URL=https://fairlens.your-domain.com
FIREBASE_PROJECT=YOUR_PROJECT_ID

# Jira integration (optional)
JIRA_BASE_URL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
